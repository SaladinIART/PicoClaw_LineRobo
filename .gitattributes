# Ensure consistent line endings
* text=auto

# Python files
*.py text eol=lf

# Markdown files
*.md text eol=lf

# Docker files
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary

# SQLite databases
*.db binary
*.sqlite binary